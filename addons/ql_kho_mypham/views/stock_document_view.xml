<?xml version="1.0" encoding="utf-8"?>
<openerp>
<data>

    <!-- SEARCH -->
<record model="ir.ui.view" id="view_stock_search">
    <field name="name">stock.search</field>
    <field name="model">mp.stock.document</field>
    <field name="type">search</field>
    <field name="arch" type="xml">

        <search string="Tìm phiếu kho">

            <!-- Tìm nhanh -->
            <field name="name"/>
            <field name="date"/>

            <!-- Bộ lọc -->
            <filter string="Phiếu nhập"
                    domain="[('type','=','in')]"/>

            <filter string="Phiếu xuất"
                    domain="[('type','=','out')]"/>

            <filter string="Đã hoàn tất"
                    domain="[('state','=','done')]"/>

            <filter string="Nháp"
                    domain="[('state','=','draft')]"/>

            <!-- Group by -->
            <group expand="0" string="Nhóm theo">
                <filter string="Loại"
                        context="{'group_by':'type'}"/>

                <filter string="Trạng thái"
                        context="{'group_by':'state'}"/>

                <filter string="Ngày"
                        context="{'group_by':'date'}"/>
            </group>

        </search>

    </field>
</record>

    <!-- TREE -->
    <record model="ir.ui.view" id="view_stock_tree">
    <field name="name">stock.tree</field>
    <field name="model">mp.stock.document</field>
    <field name="type">tree</field>
    <field name="arch" type="xml">
        <tree string="Phiếu kho"
              colors="green:state=='done';gray:state=='draft'">

            <field name="name"/>
            <field name="date"/>
            <field name="type"/>
            <field name="state"/>

        </tree>
    </field>
</record>

    <!-- FORM -->
    <record model="ir.ui.view" id="view_stock_form">
        <field name="name">stock.form</field>
        <field name="model">mp.stock.document</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
   <form string="Phiếu kho" version="7.0">

    <!-- HEADER -->
    <header>
        <button name="action_done"
                string="Hoàn tất"
                type="object"
                states="draft"
                class="oe_highlight"/>

        <field name="state"
               widget="statusbar"
               statusbar_visible="draft,done"
               readonly="1"/>
    </header>

    <sheet>

        <!-- TITLE GIỐNG PURCHASE -->
        <div class="oe_title">
            <h1>
                <label string="Phiếu kho "/>
                <field name="name" class="oe_inline" readonly="1"
                       attrs="{'invisible':[('name','=','/')]}"/>
            </h1>
        </div>

        <!-- THÔNG TIN CHÍNH -->
        <group>
            <group>
                <field name="date"
                       attrs="{'readonly':[('state','=','done')]}"/>
                <field name="type"
                       attrs="{'readonly':[('state','=','done')]}"/>
            </group>
            <group>
                <!-- có thể thêm note nếu muốn -->
            </group>
        </group>

        <!-- NOTEBOOK -->
        <notebook>

            <page string="Chi tiết sản phẩm">
                <field name="line_ids"
                       attrs="{'readonly':[('state','=','done')]}">
                    <tree editable="bottom">
                        <field name="product_id"/>
                        <field name="quantity"/>
                        <field name="note"/>
                    </tree>
                </field>
            </page>

        </notebook>

    </sheet>

</form>
        </field>
    </record>

    <!-- ACTION -->
    <record model="ir.actions.act_window" id="action_stock">
        <field name="name">Phiếu kho</field>
        <field name="res_model">mp.stock.document</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
    </record>

</data>
</openerp>