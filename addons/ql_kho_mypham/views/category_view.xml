<?xml version="1.0" encoding="utf-8"?>
<openerp>
<data>
    <!-- SEARCH -->
    <record model="ir.ui.view" id="view_category_search">
        <field name="name">category.search</field>
        <field name="model">mp.category</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search string="Search Category">
                <field name="name"/>
            </search>
        </field>
    </record>

    <!-- TREE -->
    <record model="ir.ui.view" id="view_category_tree">
        <field name="name">category.tree</field>
        <field name="model">mp.category</field>
        <field name="type">tree</field>
        <field name="arch" type="xml">
            <tree string="Danh mục">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- FORM -->
    <record model="ir.ui.view" id="view_category_form">
        <field name="name">category.form</field>
        <field name="model">mp.category</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Danh mục">
                <field name="name"/>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record model="ir.actions.act_window" id="action_category">
        <field name="name">Danh mục</field>
        <field name="res_model">mp.category</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
    </record>

</data>
</openerp>