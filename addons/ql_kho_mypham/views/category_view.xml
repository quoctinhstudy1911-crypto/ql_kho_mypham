<?xml version="1.0" encoding="utf-8"?>
<openerp>
<data>
    <!-- SEARCH -->
<record id="view_category_search" model="ir.ui.view">
    <field name="name">mp.category.search</field>
    <field name="model">mp.category</field>
    <field name="arch" type="xml">
        <search string="Tìm danh mục">
            <field name="name" string="Tên danh mục"/>

            <!-- Filter trạng thái -->
            <filter name="active_true" string="Đang sử dụng"
                    domain="[('active','=',True)]"/>

            <filter name="active_false" string="Ngưng sử dụng"
                    domain="[('active','=',False)]"
                    context="{'active_test':False}"/>

            <filter name="active_all" string="Tất cả"
                    domain="['|',('active','=',True),('active','=',False)]"
                     context="{'active_test':False}"/>

            <!-- Group -->
            <group expand="0" string="Gom nhóm...">
                <filter string="Theo trạng thái"
                        icon="terp-stock_effects-object-colorize"
                        context="{'group_by':'active','active_test':False}"/>
            </group>

        </search>
    </field>
</record>

    <!-- TREE -->
    <record id="view_category_tree" model="ir.ui.view">
        <field name="name">mp.category.tree</field>
        <field name="model">mp.category</field>
        <field name="type">tree</field>
        <field name="arch" type="xml">
            <tree string="Danh mục">
                <field name="name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>


    <!-- FORM -->
 <record model="ir.ui.view" id="view_category_form">
    <field name="name">mp.category.form</field>
    <field name="model">mp.category</field>
    <field name="type">form</field>
    <field name="arch" type="xml">

        <form string="Danh mục mỹ phẩm" version="7.0">
            <sheet>

                <!-- TITLE BLOCK -->
                <div class="oe_title" style="margin-bottom:25px;">

                    <div style="font-weight:bold;">
                        Tên danh mục:
                    </div>

                    <h1 style="margin-bottom:10px;">
                        <field name="name" placeholder="Nhập tên danh mục..."/>
                    </h1>

                    <div class="oe_grey">
                        Phân loại sản phẩm trong hệ thống kho mỹ phẩm
                    </div>

                </div>

                <!-- THÔNG TIN CHUNG -->
                <group string="Thông tin chung" col="4" style="margin-top:20px;">

                    <field name="active"/>

                </group>

                <!-- KHOẢNG CÁCH -->
                <div style="margin-top:20px;"></div>

                <!-- NOTEBOOK -->
                <notebook>

                    <page string="Mô tả">
                        <group style="margin-top:10px;">
                            <field name="description"
                                   nolabel="1"
                                   placeholder="Nhập mô tả danh mục..."/>
                        </group>
                    </page>

                </notebook>

            </sheet>
        </form>

    </field>
</record>

    <!-- ACTION -->
    <record model="ir.actions.act_window" id="action_category">
        <field name="name">Danh mục</field>
        <field name="res_model">mp.category</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
    </record>

</data>
</openerp>